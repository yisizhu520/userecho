# ========================================
# 前端项目 .gitignore (Vue 3 + Vite + pnpm)
# ========================================

# ===== 依赖 =====
node_modules/
pnpm-lock.yaml.* 
.pnpm-debug.log

# ===== 构建输出 =====
dist/
dist-ssr/
dist.zip
dist.tar
dist.war
*-dist.zip
*-dist.tar
*-dist.war
dev-dist/

# ===== 缓存 =====
.turbo/
.cache/
.eslintcache
.stylelintcache
**/.vitepress/cache/
.nitro/
.output/

# ===== 临时文件 =====
.temp/
*.local
type_errors.txt

# ===== 日志 =====
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ===== 环境变量 =====
.env.local
.env.*.local

# ===== 测试覆盖率 =====
coverage/
.nyc_output/

# ===== 编辑器 =====
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.history/

# ===== macOS =====
.DS_Store

# ===== Vite 配置临时文件 =====
vite.config.mts.*
vite.config.mjs.*
vite.config.js.*
vite.config.ts.*

# ===== Mock 数据 =====
**/backend-mock/data/

# ===== 包管理器锁文件（保留 pnpm） =====
yarn.lock
package-lock.json

# ===== 统计文件 =====
.VSCodeCounter/

# ===== 从 Vben 升级时需要删除的文件（可选） =====
# 如果需要，可以取消注释以下内容
# .github/
# .changeset/
# backend-mock/
# web-ele/
# web-naive/
# docs/
# playground/
# scripts/deploy/build-local-docker-image.sh
# scripts/deploy/Dockerfile
# .gitpod.yml
# README.*.md
# tea.yaml
