# 演示环境配置（本地开发）
NODE_ENV=development

# 应用标题
VITE_APP_TITLE=回响-演示版

# API 基础路径（本地开发使用 Vite proxy）
VITE_GLOB_API_URL=/

# 应用命名空间
VITE_APP_NAMESPACE=userecho-demo

# Demo 模式标识
VITE_DEMO_MODE=true

# Cloudflare Turnstile（本地开发使用测试密钥）
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# 是否开启调试
VITE_DEVTOOLS=true
