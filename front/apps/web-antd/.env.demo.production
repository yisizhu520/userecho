# 演示环境配置（生产部署）
NODE_ENV=production

# 应用标题
VITE_APP_TITLE=回响-演示版

# API 基础路径（生产环境使用完整 URL）
VITE_GLOB_API_URL=https://demo.userecho.app

# 应用命名空间
VITE_APP_NAMESPACE=userecho-demo

# Demo 模式标识
VITE_DEMO_MODE=true

# Cloudflare Turnstile（生产环境使用真实密钥）
VITE_TURNSTILE_SITE_KEY=0x4AAAAAAxxxxxxxxxxxxxxxxxxxxxxxx

# 是否开启调试
VITE_DEVTOOLS=false
