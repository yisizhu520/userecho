# ========================================
# 服务器项目 .gitignore
# ========================================

# ===== Python 相关 =====
# 字节码
__pycache__/
*.py[cod]
*$py.class
*.so

# ===== 虚拟环境 =====
venv/
.venv/
env/
ENV/
.python-version

# ===== IDE =====
.idea/
.vscode/
.cursor/
.DS_Store

# ===== 缓存和临时文件 =====
.ruff_cache/
.pytest_cache/
.mypy_cache/
.dmypy.json
dmypy.json
.coverage
.hypothesis/
*.cover
*.py,cover
htmlcov/
.tox/
.nox/

# ===== 日志 =====
*.log
logs/

# ===== 环境变量 =====
.env
.env.local
.env.*.local
# 真实部署配置（含密，永远不提交）
.env.prod
.env.demo
.env.staging
.env.demo.patch
.env.*.patch

# ===== 数据库 =====
*.db
*.sqlite
*.sqlite3

# ===== Celery =====
celerybeat-schedule
celerybeat.pid

# ===== 工具 =====
.claude/

# ===== 构建和发布 =====
build/
dist/
*.egg-info/
.installed.cfg
*.egg
wheels/
pip-wheel-metadata/

# ===== 备份文件 =====
*.bak
*.swp
*~

# ===== 临时诊断/调试/测试脚本（根目录一次性脚本）=====
# 这些文件是开发过程中的临时产物，不应提交到开源仓库
check_*.py
check_*.sh
diagnose_*.py
diagnose_*.sh
fix_*.py
fix_*.sh
test_*.py
test_*.sh
test_*.bat
verify_*.py
verify_*.sh
verify_*.bat
monitor_*.py
kill_*.py
kill_*.bat
kill_*.ps1
force_kill_*.ps1
quick_check.py
simple_check.py
refactor_clustering.py
reset_*.py
run_import_demo.py
gen_report.py
lower_quality_threshold.py
add_system_menus.py
add_task_center_menu.py
assign_system_admin.py
create_system_admin_role.py
list_roles.py
# 诊断输出文件
*_diagnosis.txt
*_result.txt
*_output.txt
*_output2.txt
*_after_*.txt
*_verification.txt
precommit_output.txt
migration_log.txt
type_errors.txt
# 一次性 SQL 补丁
clean_duplicate_board.sql
# backend/ 根目录临时脚本
backend/test_*.py
backend/test_*.sh
backend/test_*.bat
backend/verify_*.py
backend/verify_*.sh
backend/verify_*.bat
backend/diagnose_*.py
backend/create_test_*.py
backend/create_test_*.sh
backend/create_test_*.bat
# scripts/ 子目录一次性脚本（fix_, diagnose_, verify_ 前缀）
backend/scripts/fix_*.py
backend/scripts/diagnose_*.py
backend/scripts/verify_*.py
backend/scripts/check_boss*.py
backend/scripts/check_tenant*.py
backend/scripts/check_screenshot*.py
backend/scripts/*.sql
# Windows 特殊文件
NUL
