# ==================== 基础配置 ====================
ENVIRONMENT=dev

# ==================== 数据库配置 ====================
DATABASE_TYPE=postgresql
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password

# ==================== Redis 配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# ==================== 安全配置 ====================
TOKEN_SECRET_KEY=your-secret-key-here-use-secrets.token_urlsafe(32)
OPERA_LOG_ENCRYPT_SECRET_KEY=your-encrypt-key-here-use-os.urandom(32).hex()

# ==================== Celery 配置 ====================
CELERY_BROKER_REDIS_DATABASE=1

# ==================== OAuth2 配置 ====================
OAUTH2_GITHUB_CLIENT_ID=
OAUTH2_GITHUB_CLIENT_SECRET=
OAUTH2_GOOGLE_CLIENT_ID=
OAUTH2_GOOGLE_CLIENT_SECRET=
OAUTH2_LINUX_DO_CLIENT_ID=
OAUTH2_LINUX_DO_CLIENT_SECRET=

# ==================== Email 配置 ====================
EMAIL_USERNAME=your_email@qq.com
EMAIL_PASSWORD=your_smtp_password

# ==================== userecho AI 配置 ====================
# DeepSeek (推荐用于 Chat - 性价比高，但不支持 Embedding)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# OpenAI (支持 Embedding + Chat 全功能)
OPENAI_API_KEY=sk-your-openai-key-here

# 智谱 GLM (国内服务商，支持 Embedding + Chat 全功能)
GLM_API_KEY=your-glm-api-key-here

# 火山引擎/豆包 (国内服务商，需配置 endpoint ID)
VOLCENGINE_API_KEY=your-volcengine-api-key-here
VOLCENGINE_EMBEDDING_ENDPOINT=ep-20241221xxx-xxxxx
VOLCENGINE_CHAT_ENDPOINT=ep-20241221xxx-xxxxx

# 默认使用的 AI 提供商：deepseek / openai / glm / volcengine
AI_DEFAULT_PROVIDER=deepseek

# 注意：
# - DeepSeek 只支持 Chat，不支持 Embedding
# - 如使用 DeepSeek，建议同时配置 OpenAI 或 GLM 用于 Embedding
# - GLM 和 OpenAI 支持全功能（Embedding + Chat）

# ==================== userecho 聚类配置 ====================
CLUSTERING_SIMILARITY_THRESHOLD=0.75
CLUSTERING_MIN_SAMPLES=2

# ==================== userecho 导入配置 ====================
IMPORT_MAX_FILE_SIZE=10485760
IMPORT_ALLOWED_EXTENSIONS=.xlsx,.xls,.csv
