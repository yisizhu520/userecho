# ========================================
# 后端应用 .gitignore (FastAPI)
# ========================================

# ===== Python 字节码 =====
__pycache__/
*.py[cod]
*$py.class

# ===== 环境变量（敏感配置） =====
.env
.env.local
.env.production

# ===== 数据库迁移（版本控制的迁移文件） =====
# Alembic 生成的迁移版本文件
# alembic/versions/
# 如果需要版本控制迁移文件，请注释上一行并仅忽略特定文件
# alembic/versions/*.pyc

# ===== 静态媒体文件 =====
# 用户上传的媒体文件
static/media/
static/uploads/
media/

# ===== 日志文件 =====
*.log
logs/

# ===== Celery =====
celerybeat-schedule
celerybeat-schedule.*
celerybeat.pid
*.pid

# ===== 测试和覆盖率 =====
.pytest_cache/
.coverage
htmlcov/
.hypothesis/

# ===== 临时文件 =====
*.tmp
*.temp
tmp/
temp/

# ===== 数据库文件 =====
*.db
*.sqlite
*.sqlite3
*.db-journal

# ===== 备份文件 =====
*.bak
*.backup

# ===== 缓存 =====
.cache/
.mypy_cache/
.ruff_cache/

# ===== 本地开发文件 =====
# 本地测试数据
test_data/
# 本地配置
local_settings.py
