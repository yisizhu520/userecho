# ========================================
# userecho 项目 - 根目录 .gitignore
# ========================================

# ===== 操作系统文件 =====
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
nul

# ===== IDE 和编辑器 =====
.idea/
# .vscode/
.cursor/turbo
*.swp
*.swo
*.swn
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.history/
*.code-workspace

# ===== 日志文件 =====
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ===== 临时文件 =====
*.tmp
*.temp
.tmp/
.temp/
.cache/

# ===== 环境变量文件 =====
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
# 真实部署配置（含密钥，永远不提交）
.env.prod
.env.demo
.env.staging
.env.demo.patch
.env.*.patch

# ===== 依赖目录 (根级别) =====
node_modules/
venv/
.venv/
env/
ENV/

# ===== 构建输出 (根级别) =====
dist/
build/
out/
*.zip
*.tar
*.tar.gz
*.war

# ===== Python 相关 =====
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
pip-log.txt
pip-delete-this-directory.txt
.python-version

# ===== 测试和覆盖率 =====
coverage/
.coverage
.coverage.*
.pytest_cache/
htmlcov/
.tox/
.nox/

# ===== 数据库 =====
*.db
*.sqlite
*.sqlite3

# ===== 备份文件 =====
*.bak
*.backup
*~

# ===== 文档生成 =====
site/
docs/_build/

# ===== AI 工具私人配置 =====
.agent/
.claude/
.cursor/plans/
# 注意：保留 .cursor/rules/ 作为项目代码规范
# AI 助手指令文件（各编辑器/工具私有，不应公开）
AGENTS.md
GEMINI.md

# ===== 临时诊断/测试/调试脚本（根目录） =====
check_data.py
test_redis_connection.py
test_feedbacks*.xlsx

# ===== 其他 =====
.VSCodeCounter/
*.pid
*.seed
*.pid.lock
